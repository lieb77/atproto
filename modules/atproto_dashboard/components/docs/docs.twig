{# doc site.standard.document #}

{{ attach_library('core/htmx') }}

<div id="pds-overlay-backdrop" class="pds-overlay-backdrop" style="display:none;">
  <div class="pds-overlay">
    <button class="pds-overlay__close"
      hx-on:click="
        document.getElementById('pds-overlay-backdrop').style.display='none';
        document.getElementById('pds-overlay-content').innerHTML='';
      ">
      &times;
    </button>
    <div id="pds-overlay-content"></div>
  </div>
</div>


<div class="pds-rides">
  {% if docs is not empty %}
    <table>
      <thead>
        <tr>
          <th>Rkey</th>
          <th>Published</th>
          <th>Title</th>
          <th>Path</th>
          <th colspan=3>Actions</th>
        </tr>
      </thead>
      <tbody>
        {% for doc in docs %}
        	{% include "atproto_dashboard:doc-row" with {
        		doc: doc
        	} only  %}        
        {% endfor %}
      </tbody>
    </table>
  {% else %}
    <p>No docs found on the PDS.</p>
  {% endif %}
</div>