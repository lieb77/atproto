
<tr id="ride-{{ ride.rkey }}" class="pds-row {{ ride.sync_meta.class }} htmx-swapping">
	<td>{{ ride.rkey }}</td>
	<td>{{ ride.createdAt|date("M j, Y") }}</td>
	<td>{{ ride.url }}</td>
	
	{# Actions Column #} 
	<div class="button-group">
		<td>
			<button data-hx-post="/atproto/dashboard/view/{{ ride.rkey }}"
				data-hx-target="#pds-overlay-content"
				data-hx-swap="innerHTML"
				hx-on::after-request="document.getElementById('pds-overlay-backdrop').style.display='flex';"
				class="button--small">
				View
			</button>
		</td>
		<td>
			<button data-hx-post="/atproto/dashboard/update/{{ ride.rkey }}"
				data-hx-target="closest tr"
				data-hx-swap="outerHTML"
				class="button--small">
				Edit
			</button>
		</td>
		<td>
			<button data-hx-delete="/atproto/dashboard/delete/{{ ride.rkey }}"
				data-hx-target="#ride-{{ ride.rkey }}"
				data-hx-swap="outerHTML"
				data-hx-confirm="Delete from PDS?"
				class="button--danger button--small">
				Delete
			</button>
		</td>
	</div>
</tr>

